{
	"$schema": "https://raw.githubusercontent.com/-/tmlanguage/master/tmlanguage.json",
	"name": "LDL",
	"patterns": [
		{
			"include": "#keywords"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#conditions"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.ldl",
				"match": "\\b(if|while|for|return)\\b"
			}]
		},
		"strings": {
			"name": "string.quoted.double.ldl",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.ldl",
					"match": "\\\\."
				}
			]
		}
	},
	"scopeName": "source.ldl"
}